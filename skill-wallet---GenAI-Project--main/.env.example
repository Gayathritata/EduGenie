# =================================================================
# EduGenie Environment Configuration Settings Template
# Copy this file to '.env' and replace the placeholder values.
# =================================================================

# Server Settings
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Settings
DATABASE_URL=sqlite:///./edugenie.db

# AI API Configurations
# Obtain a Gemini key from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# Obtain a Hugging Face token from: https://huggingface.co/settings/tokens
HF_API_KEY=your-huggingface-token-here
LAMINI_MODEL_URL=https://api-inference.huggingface.co/models/MBZUAI/LaMini-Flan-T5-783M
