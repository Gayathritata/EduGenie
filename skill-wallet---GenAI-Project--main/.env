# Security settings
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database configurations
DATABASE_URL=sqlite:///./edugenie.db

# Google Gemini API key
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_API_KEY

# Hugging Face Inference API settings (for LaMini-Flan-T5)
# Get one from: https://huggingface.co/settings/tokens
HF_API_KEY=your-huggingface-api-key-here
LAMINI_MODEL_URL=https://api-inference.huggingface.co/models/MBZUAI/LaMini-Flan-T5-783M
